{
  "expo": {
    "name": "Kimori .My",
    "slug": "mobile_app",
    "scheme": "kimorimy",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon/mylogo.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/mylogo.png"
    },
    "notification": {
      "icon": "./assets/icon/notif_logo.png",
      "color": "#E6B8B1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E4C0B4",
        "foregroundImage": "./assets/icon/mylogo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lauriell.Kimori.My",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon/mylogo.png",
          "color": "#7D6B91"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E4C0B4",
          "android": {
            "image": "./assets/icon/mylogo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0da3cb39-d3a3-4c36-990e-045605fd4b85"
      }
    }
  }
}